<!DOCTYPE html>
<html>
<head>
<style>
button {
  padding: 10px 20px;
  border: none;
  margin: 5px;
  border-radius: 5px;
  cursor: pointer;
}

.normal {
  background: blue;
  color: white;
}

.outline {
  background: white;
  border: 2px solid blue;
  color: blue;
}

.success {
  background: green;
  color: white;
}

.danger {
  background: red;
  color: white;
}
</style>
</head>

<body>

<button class="normal">Normal</button>
<button class="outline">Outline</button>
<button class="success">Uğur</button>
<button class="danger">Təhlükə</button>

</body>
</html>
